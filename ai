    create-code)
        # Create a new code file in the correct location (action directory)
        action_name="$1"
        code_file="$2"
        file_type="$3"
        
        if [ -z "$action_name" ] || [ -z "$code_file" ]; then
            echo "Usage: ./ai create-code <ActionName> <file_path> [file_type]"
            echo ""
            echo "Examples:"
            echo "  ./ai create-code MyAction src/main.py python"
            echo "  ./ai create-code MyAction code/utils.js javascript"
            echo ""
            echo "Supported file types: python, javascript, typescript, java, go, ruby, php, bash, c, cpp"
            exit 1
        fi
        
        # Check if action exists
        action_dir="$AICHECK_DIR/actions/$action_name"
        if [ ! -d "$action_dir" ]; then
            echo "Error: Action '$action_name' does not exist."
            echo "Create it first with: ./ai new $action_name"
            exit 1
        fi
        
        # Detect file type if not specified
        if [ -z "$file_type" ]; then
            # Get extension
            ext="${code_file##*.}"
            case "$ext" in
                py) file_type="python" ;;
                js) file_type="javascript" ;;
                ts) file_type="typescript" ;;
                java) file_type="java" ;;
                go) file_type="go" ;;
                rb) file_type="ruby" ;;
                php) file_type="php" ;;
                sh) file_type="bash" ;;
                c|h) file_type="c" ;;
                cpp|hpp|cc) file_type="cpp" ;;
                *) file_type="generic" ;;
            esac
        fi
        
        # Check if the file path includes a directory structure
        if [[ "$code_file" == */* ]]; then
            # Path includes directory - get the directory part
            dir_part=$(dirname "$code_file")
            file_part=$(basename "$code_file")
            
            # Create a proper path in the action directory
            if [[ "$dir_part" == "src" || "$dir_part" == "code" ]]; then
                # User specified src/ or code/ - use that
                code_dir="$action_dir/$dir_part"
            else
                # User specified a subdirectory - put it under /src
                code_dir="$action_dir/src/$dir_part"
            fi
            
            full_path="$code_dir/$file_part"
        else
            # No directory structure - default to src/
            code_dir="$action_dir/src"
            full_path="$code_dir/$code_file"
